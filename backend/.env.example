# Local dev — copy to backend/.env (gitignored) and adjust as needed.

# Bypass real auth in dev: the frontend stores 'dev-admin-local' in
# localStorage on any login; this lets the backend accept it.
DEV_MODE=true

# Postgres dev DB (matches docker-compose.yml). Apply the schema with:
#   psql "$DATABASE_URL" -f backend/migrations/001_init.sql
DATABASE_URL=postgresql://dev:dev@localhost:5432/ifmlogix

# CORS for the Vite dev server.
ALLOWED_ORIGINS=http://localhost:3000

# Entra External ID (Phase C) — leave unset locally; DEV_MODE handles auth.
# Wire these up when the tenant is provisioned:
# ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
# ENTRA_CLIENT_ID=11111111-1111-1111-1111-111111111111
# ENTRA_AUTHORITY=https://logfi.ciamlogin.com  # External ID; for vanilla Entra ID use https://login.microsoftonline.com

# Production (Azure Container Apps) — leave unset locally.
# AZURE_KEY_VAULT_URL=https://kv-ifmlogix.vault.azure.net
# POSTGRES_SECRET_NAME=POSTGRES-CONN
